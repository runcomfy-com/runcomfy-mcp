# RunComfy MCP — Serverless API (ComfyUI) wrapper
RUNCOMFY_API_KEY=rc_please_replace_me

# Optional base URL override.
RUNCOMFY_SERVERLESS_BASE_URL=https://api.runcomfy.net

# Optional per-surface credential override (falls back to RUNCOMFY_API_KEY).
# RUNCOMFY_SERVERLESS_API_KEY=

# Keep the Python app mounted at /mcp behind the Worker.
RUNCOMFY_MCP_MOUNT_PREFIX=
